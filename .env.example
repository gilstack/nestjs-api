# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# URL's
ADMIN_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Databases
DATABASE_URL="postgresql://postgres:password@localhost:5432/database?schema=public"
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=database
DB_PORT=5432
DB_SSL=false
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache
CACHE_DRIVER=redis
CACHE_TTL=3600

# Queue
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=debug
ENABLE_PERF_LOGGING=true
ENABLE_QUERY_LOGGING=false
