{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "decorators": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "target": "es2022",
        "keepClassNames": true,
        "baseUrl": "./src",
        "paths": {
            "@modules/*": [
                "modules/*"
            ],
            "@shared/*": [
                "shared/*"
            ],
            "@config/*": [
                "config/*"
            ]
        }
    },
    "module": {
        "type": "commonjs"
    },
    "sourceMaps": true
}